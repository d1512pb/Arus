# URLs del motor Arus (backend en Go). Copia este archivo a .env.local para desarrollo
# o configúralas en tu plataforma de despliegue (Vercel) para producción.

# Local (por defecto si no se define nada):
NEXT_PUBLIC_ENGINE_WS_URL=ws://localhost:8080/ws
NEXT_PUBLIC_ENGINE_HTTP_URL=http://localhost:8080

# Producción (ejemplo con el motor desplegado en Railway detrás de TLS):
# NEXT_PUBLIC_ENGINE_WS_URL=wss://arus-engine.up.railway.app/ws
# NEXT_PUBLIC_ENGINE_HTTP_URL=https://arus-engine.up.railway.app
